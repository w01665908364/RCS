<Window x:Class="RobotControlSystem.Editors.EventRuleDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RobotControlSystem.Editors"
        xmlns:models="clr-namespace:RobotControlSystem.Models"
        mc:Ignorable="d"
        Title="消控事件规则设计器" 
        Height="600" 
        Width="1100"
        MinHeight="400"
        MinWidth="800"
        Background="#1e2b3a"
        Foreground="#e0e0e0"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2d4a5e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#4a6a7e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d5a6e"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1d3a4e"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid样式 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1e2b3a"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#4a6a7e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3a4a5a"/>
            <Setter Property="VerticalGridLinesBrush" Value="#3a4a5a"/>
            <Setter Property="RowBackground" Value="#1e2b3a"/>
            <Setter Property="AlternatingRowBackground" Value="#243545"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="True"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
        </Style>

        <!-- DataGrid列头样式 -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2d4a5e"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#4a6a7e"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- DataGrid单元格样式 -->
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3d5a6e"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox样式 -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2d3e4e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#4a6a7e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- CheckBox样式 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#253545" BorderBrush="#4a6a7e" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnAddRule" Content="添加规则" Style="{StaticResource ToolbarButtonStyle}" Click="BtnAddRule_Click"/>
                <Button x:Name="BtnDeleteRule" Content="删除规则" Style="{StaticResource ToolbarButtonStyle}" Click="BtnDeleteRule_Click"/>
                <Separator Width="1" Background="#4a6a7e" Margin="8,0"/>
                <Button x:Name="BtnSave" Content="保存" Style="{StaticResource ToolbarButtonStyle}" Click="BtnSave_Click"/>
                <Button x:Name="BtnRefresh" Content="刷新配方" Style="{StaticResource ToolbarButtonStyle}" Click="BtnRefresh_Click"/>
                <Separator Width="1" Background="#4a6a7e" Margin="8,0"/>
                <Button x:Name="BtnTestMatch" Content="测试匹配" Style="{StaticResource ToolbarButtonStyle}" Click="BtnTestMatch_Click"/>
            </StackPanel>
        </Border>

        <!-- 主体：规则DataGrid -->
        <DataGrid x:Name="RulesDataGrid" Grid.Row="1" Margin="10" 
                  SelectionChanged="RulesDataGrid_SelectionChanged"
                  CellEditEnding="RulesDataGrid_CellEditEnding">
            <DataGrid.Columns>
                <!-- 序号 -->
                <DataGridTextColumn Header="序号" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>

                <!-- 事件名称 -->
                <DataGridTextColumn Header="事件名称" Binding="{Binding EventName}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#2d3e4e"/>
                            <Setter Property="Foreground" Value="#e0e0e0"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- 事件类型 -->
                <DataGridComboBoxColumn Header="事件类型" Width="100" 
                                        SelectedItemBinding="{Binding EventType}"
                                        x:Name="EventTypeColumn">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding Source={x:Static local:EventRuleDesignerWindow.EventTypes}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding Source={x:Static local:EventRuleDesignerWindow.EventTypes}}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>

                <!-- 信号编码 -->
                <DataGridTextColumn Header="信号编码" Binding="{Binding SignalCode}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#2d3e4e"/>
                            <Setter Property="Foreground" Value="#e0e0e0"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- 匹配条件 -->
                <DataGridComboBoxColumn Header="匹配条件" Width="100"
                                        SelectedItemBinding="{Binding MatchCondition}"
                                        x:Name="MatchConditionColumn">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding Source={x:Static local:EventRuleDesignerWindow.MatchConditions}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding Source={x:Static local:EventRuleDesignerWindow.MatchConditions}}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>

                <!-- 执行配方 -->
                <DataGridComboBoxColumn Header="执行配方" Width="120"
                                        SelectedItemBinding="{Binding RecipeName}"
                                        x:Name="RecipeColumn">
                    <DataGridComboBoxColumn.ElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="ItemsSource" Value="{Binding Source={x:Static local:EventRuleDesignerWindow.RecipeNames}}"/>
                        </Style>
                    </DataGridComboBoxColumn.ElementStyle>
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="IsEditable" Value="True"/>
                            <Setter Property="ItemsSource" Value="{Binding Source={x:Static local:EventRuleDesignerWindow.RecipeNames}}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>

                <!-- 启用 -->
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="50"/>

                <!-- 备注 -->
                <DataGridTextColumn Header="备注" Binding="{Binding Description}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#2d3e4e"/>
                            <Setter Property="Foreground" Value="#e0e0e0"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#253545" BorderBrush="#4a6a7e" BorderThickness="0,1,0,0" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" Text="就绪" Foreground="#a0a0a0" VerticalAlignment="Center"/>

                <!-- 测试匹配区域 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" x:Name="TestPanel" Visibility="Collapsed">
                    <TextBlock Text="测试消息:" Foreground="#e0e0e0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TestMessageBox" Width="200" Background="#2d3e4e" Foreground="#e0e0e0" 
                             BorderBrush="#4a6a7e" Padding="4,2"/>
                    <Button x:Name="BtnExecuteTest" Content="执行测试" Style="{StaticResource ToolbarButtonStyle}" Margin="8,0,0,0" Click="BtnExecuteTest_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
