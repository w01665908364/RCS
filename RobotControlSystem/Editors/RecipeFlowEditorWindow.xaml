<Window x:Class="RobotControlSystem.Editors.RecipeFlowEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配方流程编辑器" Height="650" Width="1200"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <ToolBar Grid.Row="0">
            <Button x:Name="BtnNewRecipe" Content="新建配方" Click="BtnNewRecipe_Click"/>
            <TextBox x:Name="TxtRecipeName" Text="新配方" Width="150" Margin="5,0"/>
            <ComboBox x:Name="CboRecipeSelect" Width="150" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CboRecipeSelect_SelectionChanged"/>
            <Button x:Name="BtnSaveRecipe" Content="保存配方" Click="BtnSaveRecipe_Click"/>
            <Button x:Name="BtnDeleteRecipe" Content="删除配方" Click="BtnDeleteRecipe_Click" Foreground="Red"/>
            <Separator/>
            <Button x:Name="BtnSimulate" Content="执行" Click="BtnSimulate_Click"/>
            <Separator/>
            <TextBlock Text="模板:" Margin="5,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="CboTemplateSelect" Width="150" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CboTemplateSelect_SelectionChanged"/>
            <Separator/>
            <Button x:Name="BtnAgvEmergencyStop" Content="AGV强制终止" Click="BtnAgvEmergencyStop_Click" Background="#d9534f" Foreground="White"/>
            <Button x:Name="BtnArmEmergencyStop" Content="机械臂强制终止" Click="BtnArmEmergencyStop_Click" Background="#d9534f" Foreground="White"/>
            <Separator/>
            <TextBlock x:Name="TxtStatus" Text="就绪" Margin="10,0" VerticalAlignment="Center"/>
        </ToolBar>

        <!-- 主区域：三列布局 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧组件库 -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="5" Background="#2b3e4f">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="步骤组件库" FontWeight="Bold" Margin="0,0,0,10" Foreground="White"/>
                        <GroupBox Header="AGV控制" Foreground="#c0d0e0">
                            <StackPanel>
                                <Button Content="AGV导航" Tag="AGV导航" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2" Click="Button_Click"/>
                                <Button Content="AGV停止" Tag="AGV停止" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                                <Button Content="AGV继续导航" Tag="AGV继续导航" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="机械臂操作" Foreground="#c0d0e0" Margin="0,5,0,0">
                            <StackPanel>
                                <Button Content="机械臂按压" Tag="机械臂按压" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2" Click="Button_Click_1"/>
                                <Button Content="机械臂旋转" Tag="机械臂旋转" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                                <Button Content="机械臂复位" Tag="机械臂复位" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="流程控制" Foreground="#c0d0e0" Margin="0,5,0,0">
                            <StackPanel>
                                <Button Content="延时" Tag="延时" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                                <Button Content="for循环" Tag="for循环" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                                <Button Content="if条件" Tag="if条件" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="系统运维" Foreground="#c0d0e0" Margin="0,5,0,0">
                            <StackPanel>
                                <Button Content="日志保存" Tag="日志保存" MouseDoubleClick="ComponentItem_MouseDoubleClick" Margin="0,2"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 中间画布区 -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,1,0" Background="#263746">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="FlowCanvas" Width="1200" Height="800" 
                            Background="Transparent"
                            MouseDown="FlowCanvas_MouseDown"
                            MouseMove="FlowCanvas_MouseMove"
                            MouseUp="FlowCanvas_MouseUp"/>
                </ScrollViewer>
            </Border>

            <!-- 右侧属性面板 -->
            <Border Grid.Column="2" Padding="5" Background="#2b3e4f">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="步骤参数" FontWeight="Bold" Margin="0,0,0,10" Foreground="White"/>
                        <Border x:Name="NoSelectionPanel" Visibility="Visible">
                            <TextBlock Text="请选择一个步骤" Foreground="Gray" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel x:Name="NodePropertyPanel" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="2" Background="#1e2b3a">
            <StatusBarItem>
                <TextBlock x:Name="StatusStep" Text="步骤数: 0" Foreground="#b0c4de"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusDb" Text="数据库: 正常" Foreground="#b0c4de"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalContentAlignment="Stretch" Width="400">
                <TextBox x:Name="ExecutionLog" 
                         Text="执行日志" 
                         Foreground="LightGray" 
                         Background="#0f1a24"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MaxHeight="60"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>