<Window x:Class="RobotControlSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="消防巡检机器人操作平台" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#1e2b3a"
        Foreground="#e0e0e0"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3a4e62"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4f6f8f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2d3e50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a4e62"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1e2b3a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a4e62"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏（标题真正居中） -->
        <Border Grid.Row="0" Background="#0078D4" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" Text="消防巡检机器人操作平台" 
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>

                <!-- 火警状态显示（动态更新） -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="火警" Foreground="White" FontSize="16" Margin="0,0,10,0"/>
                    <Border x:Name="borderFireAlarm" Background="#4CAF50" CornerRadius="12" Padding="8,4">
                        <TextBlock x:Name="txtFireAlarmStatus" Text="无火警·正常" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 操作按钮行（靠左排列） -->
        <Border Grid.Row="1" Background="#2b3e4f" Padding="10" BorderBrush="#1e2b3a" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="btnOpenPanelEditor" Content="操作面板配置" Width="140" Height="36" Margin="10,0" Click="BtnOpenPanelEditor_Click" Background="#5bc0de"/>
                <Button x:Name="btnOpenRecipeEditor" Content="配方流程" Width="140" Height="36" Margin="10,0" Click="BtnOpenRecipeEditor_Click" Background="#5cb85c"/>
                
                <Button x:Name="btnFireMonitor" Content="消防实时监控" Width="140" Height="36" Margin="10,0" Click="BtnFireMonitor_Click" Background="#007ACC"/>
                <Button x:Name="btnEventRuleDesigner" Content="事件规则" Width="140" Height="36" Margin="10,0" Click="BtnEventRuleDesigner_Click" Background="#f0ad4e"/>
            </StackPanel>
        </Border>

        <!-- 主体内容（可拖动调整大小的四列布局） -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- 第1列：小车/机器 -->
                <ColumnDefinition Width="1*"/>
                <!-- GridSplitter 1 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 第2列：小车地图 -->
                <ColumnDefinition Width="4*"/>
                <!-- GridSplitter 2 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 第3列：操作面板编辑器 -->
                <ColumnDefinition Width="4*"/>
                <!-- GridSplitter 3 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 第4列：配方 -->
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- GridSplitter 1 -->
            <GridSplitter Grid.Column="1" Width="5" Background="#3a4e62"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"
                          ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

            <!-- GridSplitter 2 -->
            <GridSplitter Grid.Column="3" Width="5" Background="#3a4e62"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"
                          ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

            <!-- GridSplitter 3 -->
            <GridSplitter Grid.Column="5" Width="5" Background="#3a4e62"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"
                          ShowsPreview="True" ResizeBehavior="PreviousAndNext"/>

            <!-- ========== 第1列：左侧：小车/机械臂控制 ========== -->
            <Border Grid.Column="0" Background="#2b3e4f" Padding="8" BorderBrush="#1e2b3a" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="小车/机器" FontSize="18" FontWeight="Bold" Foreground="#c0d0e0" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- 车辆选择 -->
                        <TextBlock Text="选择小车" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbVehicle" SelectedIndex="0" Margin="0,0,0,10"  Foreground="Black" SelectionChanged="CmbVehicle_SelectionChanged">
                            <ComboBoxItem Content="AMB-01" Tag="AMB-01"/>
                            <ComboBoxItem Content="AMB-02" Tag="AMB-02"/>
                            <ComboBoxItem Content="car1" Tag="car1"/>
                            <ComboBoxItem Content="car2" Tag="car2"/>
                        </ComboBox>

                        <!-- AGV 控制 -->
                        <Button x:Name="btnGetAgvStatus" Content="获取状态" Click="BtnGetAgvStatus_Click"/>
                        <Button x:Name="btnLockAgv" Content="获取AGV控制权" Click="BtnLockAgv_Click"/>
                        <Button x:Name="btnForceLockAgv" Content="强制抢夺控制权" Click="BtnForceLockAgv_Click"/>
                        <Button x:Name="btnUnlockAgv" Content="释放控制权" Click="BtnUnlockAgv_Click"/>
                        <Button x:Name="btnClearOrders" Content="清除所有运单" Click="BtnClearOrders_Click" Background="#d9534f"/>

                        <!-- 站点导航（下拉选择版） -->
                        <TextBlock Text="站点导航" FontWeight="Bold" Margin="0,10,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cmbSite" Grid.Column="0" SelectedIndex="0" Margin="0,0,5,0"  Foreground="Black">
                                <ComboBoxItem Content="AP3" Tag="AP3"/>
                                <ComboBoxItem Content="AP4" Tag="AP4"/>
                            </ComboBox>
                            <Button x:Name="btnNavigate" Grid.Column="1" Content="导航" Click="BtnNavigate_Click" Width="60" Background="#5bc0de"/>
                        </Grid>

                        <!-- 机器人控制（带IP/端口输入） -->
                        <TextBlock Text="机械臂控制" FontWeight="Bold" Margin="0,10,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtRobotIP" Text="192.168.1.60" Margin="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="端口:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtRobotPort" Text="29999" Margin="2"/>
                        </Grid>

                        <Button x:Name="btnConnectRobot" Content="连接机器人" Click="BtnConnectRobot_Click" Background="#4CAF50"/>
                        <Button x:Name="btnPowerOn" Content="机器人上电" Click="BtnPowerOn_Click" IsEnabled="true"/>
                        <Button x:Name="btnReleaseBrake" Content="释放抱闸" Click="BtnReleaseBrake_Click" IsEnabled="true"/>
                        <Button x:Name="btnRunTask" Content="运行任务" Click="BtnRunTask_Click" IsEnabled="True"/>
                        <Button x:Name="btnQueryStatus" Content="查询状态" Click="BtnQueryStatus_Click" IsEnabled="true"/>

                        <!-- 状态显示 -->
                        <Border Background="#1e2b3a" CornerRadius="4" Margin="0,10,0,0" Padding="4">
                            <StackPanel>
                                <TextBlock x:Name="txtAgvLockStatus" Text="AGV: 未锁定" Foreground="#ffaa00"/>
                                <TextBlock x:Name="txtRobotStatus" Text="机器人: 未连接" Foreground="#ffaa00"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ========== 第2列：小车地图（支持Ctrl+滚轮缩放） ========== -->
            <Border Grid.Column="2" Background="#0f1a24" BorderBrush="#3a4e62" BorderThickness="1" CornerRadius="6" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="小车地图" FontSize="18" FontWeight="Bold" Foreground="#c0d0e0" Margin="8,4"/>
                        <TextBlock Text="实时定位" Foreground="#ffaa00" VerticalAlignment="Center" Margin="8,0"/>
                    </StackPanel>

                    <!-- 查询参数行 -->
                    <Grid Grid.Row="1" Margin="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="机器人名:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="txtMapVehicle" Text="AMB-01" Margin="4"/>
                        <TextBlock Grid.Column="2" Text="地图名:" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBox Grid.Column="3" x:Name="txtMapName" Text="20260128101233782.smap" Margin="4"/>
                        <Button Grid.Column="4" x:Name="btnQueryMap" Content="查询并渲染地图" Click="BtnQueryMap_Click" Width="140" Margin="4"/>
                    </Grid>

                    <!-- 地图容器（添加ScrollViewer以支持滚动和缩放） -->
                    <Border Grid.Row="2" Background="#0f1a24" Padding="4">
                        <ScrollViewer x:Name="MapScrollViewer" 
                                      HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="MapScrollViewer_PreviewMouseWheel">
                            <Grid x:Name="MapContainer" 
                                  Width="{Binding ActualWidth, ElementName=MapScrollViewer, Mode=OneWay}"
                                  Height="{Binding ActualHeight, ElementName=MapScrollViewer, Mode=OneWay}"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="MapScaleTransform" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Image x:Name="mapImage" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Canvas x:Name="mapOverlayCanvas" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" ClipToBounds="True"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== 第3列：操作面板编辑器预览（支持Ctrl+滚轮缩放） ========== -->
            <Border Grid.Column="4" Background="#0f1a24" BorderBrush="#3a4e62" BorderThickness="1" CornerRadius="6" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="操作面板编辑器" FontSize="18" FontWeight="Bold" Foreground="#c0d0e0" Margin="8,4"/>
                        <TextBlock Text="拖拽布局" Foreground="#ffaa00" VerticalAlignment="Center" Margin="8,0"/>
                    </StackPanel>

                    <!-- 模板选择行 -->
                    <Grid Grid.Row="1" Margin="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="选择模板:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="cmbTemplate" DisplayMemberPath="Name"  Foreground="Black" SelectedValuePath="Id" SelectionChanged="CmbTemplate_SelectionChanged" Margin="4"/>
                        <Button Grid.Column="2" x:Name="btnRefreshPanel" Content="刷新预览" Click="BtnRefreshPanel_Click" Width="80" Margin="4"/>
                    </Grid>

                    <!-- 画布预览（添加ScrollViewer以支持滚动和缩放） -->
                    <Border Grid.Row="2" Background="#1e1e1e" BorderBrush="#3a4e62" BorderThickness="1" CornerRadius="4" Padding="4">
                        <ScrollViewer x:Name="PanelScrollViewer" 
                                      HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="PanelScrollViewer_PreviewMouseWheel">
                            <Grid x:Name="PanelContainer" 
                                  Width="800" Height="600"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="PanelScaleTransform" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Canvas x:Name="panelCanvas" Width="800" Height="600" Background="#1e1e1e" MouseDown="PanelCanvas_MouseDown"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== 第4列：配方快速执行 ========== -->
            <Border Grid.Column="6" Background="#2b3e4f" Padding="8" BorderBrush="#1e2b3a" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="配方" FontSize="18" FontWeight="Bold" Foreground="#c0d0e0" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="快速" Foreground="#ffaa00" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="RecipeItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}" 
                                            Tag="{Binding Id}"
                                            Click="RecipeButton_Click"
                                            Background="#337ab7" Height="32" Margin="2"
                                            Foreground="White"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>