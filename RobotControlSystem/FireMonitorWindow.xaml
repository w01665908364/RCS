<Window x:Class="RobotControlSystem.FireMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RobotControlSystem"
        xmlns:vm="clr-namespace:RobotControlSystem.ViewModels"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="消防设备实时监控" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:MessageTypeToColorConverter x:Key="MessageTypeToColorConverter"/>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <DataTemplate x:Key="DeviceDataTemplate">
            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="5" ToolTip="{Binding RawJson}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>    <!-- 时间 -->
                        <ColumnDefinition Width="150"/>   <!-- 设备编码 -->
                        <ColumnDefinition Width="80"/>    <!-- 消息类型 -->
                        <ColumnDefinition Width="60"/>    <!-- 回路 -->
                        <ColumnDefinition Width="60"/>    <!-- 节点 -->
                        <ColumnDefinition Width="120"/>   <!-- 事件时间 -->
                        <ColumnDefinition Width="*"/>     <!-- 地址 -->
                        <ColumnDefinition Width="80"/>    <!-- 状态 -->
                        <ColumnDefinition Width="50"/>    <!-- 详细按钮 -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='MM-dd HH:mm'}" 
                               VerticalAlignment="Center" FontFamily="Consolas"/>
                    <TextBlock Grid.Column="1" Text="{Binding DeviceCode}" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <Border Grid.Column="2" CornerRadius="3" Padding="3,1">
                        <Border.Background>
                            <Binding Path="MessageType" Converter="{StaticResource MessageTypeToColorConverter}"/>
                        </Border.Background>
                        <TextBlock Text="{Binding MessageType}" Foreground="White" 
                                   HorizontalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Grid.Column="3" Text="{Binding LoopNo}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="{Binding NodeNo}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="{Binding EventTime}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="{Binding Address}" 
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="7" CornerRadius="3" Padding="3,1">
                        <Border.Background>
                            <Binding Path="StatusCode" Converter="{StaticResource StatusToColorConverter}"/>
                        </Border.Background>
                        <TextBlock Text="{Binding StatusName}" Foreground="White" 
                                   HorizontalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <Button Grid.Column="8" Content="详细" Width="40" Height="20" 
                            HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="AlertDataItemStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusCode}" Value="1">
                    <Setter Property="Background" Value="#FFF0F0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusCode}" Value="0">
                    <Setter Property="Background" Value="#FFF8E1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>



    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#007ACC" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="消防设备实时监控系统" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding StatusText}" Margin="20,0,0,0" 
                           VerticalAlignment="Center" Foreground="White" FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="连接" 
                        Width="80" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" Click="Button_Click"/>
                <Button Content="断开" 
                        Width="80" Margin="0,0,10,0" Background="#F44336" Foreground="White"/>
                <Button Content="重连" 
                        Width="80" Margin="0,0,10,0" Background="#FF9800" Foreground="White"/>

                <Button Content="清空数据" Width="80" Margin="10,0,10,0" Click="BtnClearData_Click"/>
                <Button Content="测试数据" 
                        Width="80" Margin="0,0,10,0"/>

                <CheckBox Content="仅显示报警/故障" 
                          VerticalAlignment="Center" Margin="10,0,10,0"/>

                <TextBlock Text="设备编码过滤:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Width="120" VerticalAlignment="Center"/>

                <TextBlock Text="消息统计:" VerticalAlignment="Center" FontWeight="Bold" Margin="20,0,5,0"/>
                <TextBlock Text="总数:" VerticalAlignment="Center" Margin="0,0,2,0"/>
                <TextBlock Text="{Binding TotalMessagesReceived}" 
                           VerticalAlignment="Center" Foreground="Blue" FontWeight="Bold" Margin="0,0,10,0"/>

                <TextBlock Text="设备:" VerticalAlignment="Center" Margin="0,0,2,0"/>
                <TextBlock Text="{Binding DeviceStatusCount}" 
                           VerticalAlignment="Center" Foreground="Green" FontWeight="Bold" Margin="0,0,10,0"/>

                <TextBlock Text="报警:" VerticalAlignment="Center" Margin="0,0,2,0"/>
                <TextBlock Text="{Binding AlertCount}" 
                           VerticalAlignment="Center" Foreground="Red" FontWeight="Bold" Margin="0,0,10,0"/>

                <Ellipse Width="10" Height="10" Margin="20,0,5,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="Red"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="LimeGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding StatusText}" 
                           VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Padding="10" Background="#F5F5F5">
            <UniformGrid Columns="4" Margin="0,5">
                <Border CornerRadius="5" Background="White" BorderBrush="#DDD" BorderThickness="1" 
                        Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="设备状态" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="{Binding DeviceStatusCount}" 
                                   FontSize="24" FontWeight="Bold" Foreground="#2196F3"/>
                        <TextBlock Text="条消息" FontSize="10" Foreground="#999"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="5" Background="White" BorderBrush="#DDD" BorderThickness="1" 
                        Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="消防主机" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="{Binding FireMainCount}" 
                                   FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                        <TextBlock Text="条消息" FontSize="10" Foreground="#999"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="5" Background="White" BorderBrush="#DDD" BorderThickness="1" 
                        Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="模拟量数据" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="{Binding AnalogCount}" 
                                   FontSize="24" FontWeight="Bold" Foreground="#9C27B0"/>
                        <TextBlock Text="条消息" FontSize="10" Foreground="#999"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="5" Background="White" BorderBrush="#DDD" BorderThickness="1" 
                        Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="报警/故障" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="{Binding AlertCount}" 
                                   FontSize="24" FontWeight="Bold" Foreground="#F44336"/>
                        <TextBlock Text="条消息" FontSize="10" Foreground="#999"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="5" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F0F0F0" Padding="10" CornerRadius="3,3,0,0">
                        <TextBlock Text="实时数据流" FontWeight="Bold" FontSize="14"/>
                    </Border>

                    <ListView Grid.Row="1" ItemsSource="{Binding AllDataList}" 
                              ItemTemplate="{StaticResource DeviceDataTemplate}"
                              VirtualizingPanel.IsVirtualizing="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch"/>

            <Border Grid.Column="2" Margin="5" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFEBEE" Padding="10" CornerRadius="3,3,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="Red" Margin="0,0,5,0"/>
                            <TextBlock Text="报警与故障" FontWeight="Bold" FontSize="14" Foreground="#C62828"/>
                        </StackPanel>
                    </Border>

                    <ListView Grid.Row="1" ItemsSource="{Binding AlertDataList}"
                              VirtualizingPanel.IsVirtualizing="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AlertDataItemStyle}" 
                                        BorderThickness="0,0,0,1" BorderBrush="#FFCDD2" 
                                        Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceCode}" FontWeight="Bold" 
                                                   Foreground="#D32F2F" FontSize="11"/>
                                        <TextBlock Text="{Binding StatusName}" Margin="0,2,0,0"
                                                   Foreground="#E53935" FontSize="10"/>
                                        <TextBlock Text="{Binding Address}" Margin="0,2,0,0"
                                                   Foreground="#666" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" 
                                                   Foreground="#999" FontSize="8" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="4" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock Text="实时消防监控系统 v1.0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="连接状态:"/>
                    <TextBlock Text="{Binding StatusText}" Margin="5,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="最后更新:"/>
                    <TextBlock Text="{Binding LastUpdateTime, StringFormat='HH:mm:ss'}" 
                               Margin="5,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
